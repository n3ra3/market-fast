# ── Market.CSGO ────────────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО. Секретный ключ из личного кабинета market.csgo.com.
MARKET_API_KEY=your_market_api_key_here

# Валюта канала: USD | EUR | RUB (канал public:items:730:<cur>).
MARKET_CURRENCY=USD
# Масштаб units цены: USD/EUR=1000 ($0.150 -> 150), RUB=100. Менять без нужды не надо.
# PRICE_UNITS_SCALE=1000

# ── Rate limiter ───────────────────────────────────────────────────────────
# Market снимает ключ при >5 req/s. Держим ≤ 4. Резерв под покупку — 1 токен.
MARKET_MAX_RPS=4
RATE_BUY_RESERVE=1

# ── Покупка ────────────────────────────────────────────────────────────────
# id        -> покупать конкретный оффер из WS (быстрее), откат на hash_name
# hash_name -> всегда самый дешёвый ≤ лимита по имени
BUY_BY=id
BUYER_WORKERS=2
BUY_TIMEOUT_SEC=6

# ── Discovery (ПЕРВЫЙ ЗАПУСК) ──────────────────────────────────────────────
# 1 -> только слушать и логировать сырые пуши, НЕ покупать. Для калибровки схемы.
DISCOVERY_MODE=0
DISCOVERY_SAMPLE=20
# Если после калибровки поля в пуше другие — поправь без правки кода:
# WS_NAME_ID_KEYS=name_id,nameId,i,n
# WS_PRICE_KEYS=price,value,p,c
# WS_OFFER_ID_KEYS=id,offer_id,offerId,o
# WS_PRICE_FORMAT=value   # value (0.142) или units (142)

# ── Репрайсер (продажа: держим мои лоты на 1-м месте) ──────────────────────
# Развязан с покупкой; запросы priority=False. Полы только в RAM, сбрасываются
# при рестарте (после старта выключен, пока не задашь пол в Telegram → «Продажа»).
REPRICER_ENABLED=1
REPRICE_INTERVAL_SEC=60
REPRICE_STEP_UNITS=1
# SELL_CURRENCY=USD
BIDASK_WITH_ALFASKINS=1
# MARKET_READ_PRICE_FORMAT=value   # value ('441.5900') или units
REPRICE_DISCOVERY_SAMPLE=5
BOOK_DEPTH=3

# ── WatchList ──────────────────────────────────────────────────────────────
WATCHLIST_PATH=watchlist.json

# ── Telegram (информирование + установка лимитов) ──────────────────────────
MARKET_TELEGRAM_TOKEN=your_telegram_bot_token_here
MARKET_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Прогрев соединения ─────────────────────────────────────────────────────
WARMUP_ENABLED=1
WARMUP_INTERVAL_SEC=60

# ── Монитор статуса продаж (уведомление в TG, если лоты пропали) ────────────
# Без Steam/куки: смотрит /items и шлёт уведомление, если активных лотов 0.
SALES_MONITOR_ENABLED=1
SALES_CHECK_INTERVAL_SEC=120
SALES_ZERO_STREAK=2

# ── Health / Render ────────────────────────────────────────────────────────
# Render сам задаёт PORT. Локально по умолчанию 8000.
# PORT=8000

# ── Логи ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
